PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=civiflow
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=civiflow_super_secret_jwt_key_2024
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# SLA Hours per category
SLA_ROAD=48
SLA_WATER=24
SLA_SANITATION=24
SLA_ELECTRICITY=12
SLA_OTHER=72

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
