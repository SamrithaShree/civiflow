{
  "name": "civiflow-backend",
  "version": "1.0.0",
  "description": "CiviFlow Civic Issue Lifecycle Management - Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "psql -U postgres -d civiflow -f migrations/001_schema.sql",
    "seed": "psql -U postgres -d civiflow -f seeds/seed.sql",
    "db:create": "createdb -U postgres civiflow"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
